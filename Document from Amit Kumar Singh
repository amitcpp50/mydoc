   "source": [
    "def nifty():\n",
    "    headers = {'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; '\n",
    "            'x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/79.0.3945.117 Safari/537.36'}\n",
    "\n",
    "    main_url = \"https://www.nseindia.com/\"\n",
    "    response = requests.get(main_url, headers=headers)\n",
    "    print(response.status_code)\n",
    "    cookies = response.cookies\n",
    "    \n",
    "    url = \"https://www.nseindia.com/api/equity-stockIndices?index=NIFTY%2050\"\n",
    "    nifty_oi_data = requests.get(url, headers=headers, cookies=cookies)\n",
    "    data = nifty_oi_data.json()\n",
    "    \n",
    "    list_of_records = data['data']\n",
    "    df= pd.DataFrame(list_of_records)\n",
    "    df= df[['symbol', 'totalTradedVolume']]\n",
    "    df.insert(0, 'sno.', range(0, 0 + len(df)))\n",
    "    return df"
   ]
  },
